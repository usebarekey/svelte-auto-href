{
	"name": "svelte-auto-href",
	"version": "1.0.1",
	"description": "Autocomplete-friendly href types and route manifests for SvelteKit apps.",
	"license": "BSD-3-Clause",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/usebarekey/svelte-auto-href.git"
	},
	"bin": {
		"svelte-auto-href": "./.dist/cli.mjs"
	},
	"files": [
		".dist",
		"README.md"
	],
	"type": "module",
	"exports": {
		".": {
			"types": "./.dist/mod.d.mts",
			"default": "./.dist/mod.mjs"
		},
		"./vite": {
			"types": "./.dist/vite.d.mts",
			"default": "./.dist/vite.mjs"
		},
		"./editor": {
			"types": "./.dist/editor.d.mts",
			"default": "./.dist/editor.mjs"
		},
		"./generator": {
			"types": "./.dist/generator.d.mts",
			"default": "./.dist/generator.mjs"
		},
		"./html-data": {
			"types": "./.dist/html-data-renderer.d.mts",
			"default": "./.dist/html-data-renderer.mjs"
		},
		"./init": {
			"types": "./.dist/init.d.mts",
			"default": "./.dist/init.mjs"
		},
		"./cli": {
			"types": "./.dist/cli.d.mts",
			"default": "./.dist/cli.mjs"
		},
		"./manifest": {
			"types": "./.dist/manifest.d.mts",
			"default": "./.dist/manifest.mjs"
		},
		"./scanner": {
			"types": "./.dist/route-scanner.d.mts",
			"default": "./.dist/route-scanner.mjs"
		},
		"./type-renderer": {
			"types": "./.dist/type-renderer.d.mts",
			"default": "./.dist/type-renderer.mjs"
		}
	},
	"scripts": {
		"build": "cross-env NODE_PATH=./node_modules vp pack --out-dir .dist",
		"check": "vp check",
		"fmt": "vp fmt . --write",
		"lint": "vp lint",
		"test": "cross-env NODE_PATH=./node_modules vp pack --out-dir .dist && vp test run"
	},
	"dependencies": {
		"jsonc-parser": "^3.3.1",
		"typescript": "^6.0.0"
	},
	"devDependencies": {
		"@types/node": "^26.1.0",
		"cross-env": "^10.1.0",
		"vite": "catalog:",
		"vitest": "^4.1.9"
	},
	"peerDependencies": {
		"@sveltejs/kit": "^2.0.0 || ^3.0.0-next.0",
		"svelte": "^5.0.0",
		"vite": "^7.0.0 || ^8.0.0"
	},
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"version": "11.10.0",
			"onFail": "download"
		}
	},
	"engines": {
		"node": "^22.12.0 || >=24.0.0"
	},
	"packageManager": "pnpm@11.10.0"
}
